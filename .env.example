# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
# Found at: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────────────────────────────────────
# Twilio (SMS)
# ─────────────────────────────────────────────────────────────────────────────
# Found at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890   # Your Twilio phone number (international format)

# ─────────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────────
# A random secret to protect the cron endpoint from unauthorized triggers.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret

# A separate secret to access the /admin page.
ADMIN_SECRET=your-random-admin-secret

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
